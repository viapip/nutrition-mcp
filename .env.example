# Postgres password for the docker-compose stack. The app's DATABASE_URL is
# derived from it inside docker-compose.yml, so it must be URL-safe:
# letters/digits/dashes only, no @ : / # ? characters.
POSTGRES_PASSWORD=change-me

# Only needed when running the server outside docker compose (e.g. bun run dev
# against a local Postgres).
# DATABASE_URL=postgres://nutrition:change-me@localhost:5432/nutrition

# Public origin of the server; used to build absolute download links for CSV
# exports. Defaults to http://localhost:8080 when unset.
BASE_URL=https://your-domain.com

OAUTH_CLIENT_ID=your-client-id
OAUTH_CLIENT_SECRET=your-client-secret

# Google login (optional). When unset, only email/password sign-in is available.
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Open Food Facts requires a User-Agent identifying your app + contact, in the
# form "AppName (email)". Used for barcode lookups (lookup_barcode tool).
OFF_USER_AGENT=nutrition-mcp (you@example.com)

# Chat endpoint (/api/chat) for the mobile app. Any OpenAI-compatible provider
# works; defaults target Kimi (Moonshot). When LLM_API_KEY is unset, /api/chat
# returns chat_not_configured and everything else works as usual.
LLM_API_KEY=your-llm-api-key
# LLM_BASE_URL=https://api.moonshot.ai/v1
# LLM_MODEL=kimi-k2.6

PORT=8080
