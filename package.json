{
    "name": "nutrition-mcp",
    "version": "1.14.2",
    "description": "A remote MCP server for personal nutrition tracking. Log meals, track macros, and review nutrition history through Claude.",
    "author": "akutishevsky",
    "license": "MIT",
    "homepage": "https://nutrition-mcp.com",
    "repository": {
        "type": "git",
        "url": "https://github.com/akutishevsky/nutrition-mcp.git"
    },
    "keywords": [
        "mcp",
        "nutrition",
        "meal-tracking",
        "claude",
        "model-context-protocol"
    ],
    "module": "index.ts",
    "type": "module",
    "private": true,
    "devDependencies": {
        "@types/bun": "latest"
    },
    "peerDependencies": {
        "typescript": "^5.9.3"
    },
    "scripts": {
        "start": "bun src/index.ts",
        "dev": "bun --watch src/index.ts",
        "format": "bunx prettier --write .",
        "depersonalize": "bun run scripts/depersonalize.ts",
        "generate-oauth-creds": "echo \"OAUTH_CLIENT_ID=$(openssl rand -hex 16)\" && echo \"OAUTH_CLIENT_SECRET=$(openssl rand -hex 32)\""
    },
    "dependencies": {
        "@modelcontextprotocol/sdk": "^1.29.0",
        "hono": "^4.12.28",
        "jose": "^6.2.3",
        "prettier": "^3.9.4"
    }
}
